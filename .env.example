# --- model API keys ---
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# Nemotron: set EITHER NVIDIA_API_KEY (direct access) OR OPENROUTER_API_KEY (fallback).
# The adapter auto-detects whichever is present. NEMOTRON_MODEL = the exact slug you're given.
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
NEMOTRON_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# --- Gemini and Google Cloud ---
# Local: set GOOGLE_API_KEY (AI Studio). Prod: set GCP_PROJECT to use Vertex AI via ADC,
# which also enables BigQuery.
GOOGLE_API_KEY=
GCP_PROJECT=
GCP_REGION=us-central1
BQ_DATASET=litigation

# --- Neo4j Aura (creds shown once at instance creation — save them) ---
# Most Aura instances use user=neo4j, database=neo4j. Some use the instance ID for
# both (check your downloaded credentials file); set them to match.
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# --- Nemotron caps (enforced in router.py) ---
NEMOTRON_DAILY_CAP=50
NEMOTRON_MINUTE_CAP=20
