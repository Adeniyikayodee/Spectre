# --- model API keys ---
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# Nemotron: set EITHER NVIDIA_API_KEY (direct access) OR OPENROUTER_API_KEY (fallback).
# The adapter auto-detects whichever is present. NEMOTRON_MODEL = the exact slug you're given.
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
NEMOTRON_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# --- Google Cloud (no keys; uses gcloud ADC). Setting GCP_PROJECT enables Gemini + BigQuery ---
GCP_PROJECT=
GCP_REGION=us-central1
BQ_DATASET=litigation

# --- Neo4j Aura (creds shown once at instance creation — save them) ---
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- Nemotron caps (enforced in router.py) ---
NEMOTRON_DAILY_CAP=50
NEMOTRON_MINUTE_CAP=20
